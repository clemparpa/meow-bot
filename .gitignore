.DS_Store
*.log
*.swp
.venv/
.idea/
.vscode/
tmp/
node_modules/
*.bak

# Self-host runtime artifacts
# Use `dir/*` rather than `dir/` so the `!.../.gitkeep` exception is honored —
# git cannot re-include a file under a parent that's been excluded as a dir.
secrets/*
!secrets/.gitkeep
data/*
!data/.gitkeep
*.pem
.env
!.env.example
*.pyc
.claude/worktrees/*

# Local dev overrides — used for smoke-testing the bot against a
# personal GitHub App without committing the manifest or compose tweaks.
compose.override.yml
manifest/*.local.json
