# meow-bot runtime configuration (see spec §15.3).
# Copy this file to `.env` and fill in real values before booting the stack.

# Public hostname Caddy should serve and that GitHub webhooks reach.
MEOW_DOMAIN=

# GitHub App credentials (created via the manifest flow, spec §4.3).
GITHUB_APP_ID=
GITHUB_WEBHOOK_SECRET=
# GitHub App private key — provide ONE of the two below.
#   `GITHUB_APP_PRIVATE_KEY`      → inline PEM content (multi-line). Wins
#                                   when both are set. Handy on PaaS hosts
#                                   (Koyeb, Fly, Render…) where mounting a
#                                   file is awkward but env vars are not.
#   `GITHUB_APP_PRIVATE_KEY_PATH` → path to the PEM file inside the
#                                   container/process.
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_PRIVATE_KEY_PATH=/secrets/github-app.pem

# Mistral Workflows API key (workflow.run / worker triggers, spec §7).
# Also identifies the workspace/deployment the worker connects to AND backs
# the receiver's Mistral SDK client — keep this as your standard API key.
MISTRAL_API_KEY=

# Optional. Inference key handed to the `vibe` CLI inside the sandbox.
# Set this to a cheaper Mistral Vibe subscription key to drive the reviews
# without changing the workspace key above. Left empty, vibe falls back to
# MISTRAL_API_KEY (single-key setups need nothing here).
MISTRAL_VIBE_API_KEY=

# Mistral Workflows deployment name — groups the receiver and worker(s)
# of one service together (spec §7). Pick a stable identifier per
# environment; workers sharing this name share their task queues.
DEPLOYMENT_NAME=meow-bot

# Koyeb API token for ephemeral sandboxes (spec §8). The default
# `koyeb/sandbox` image ships with mistral-vibe pre-installed.
KOYEB_API_TOKEN=

# Required. GitHub login of the bot, e.g. `meow-bot[bot]`. Used by the
# receiver to drop self-deliveries (anti-loop) and by the worker to match
# `@<bot> review` mentions on PRs. Renseigné après création de la GitHub
# App (cf. docs/quickstart.md §8) — le slug `[bot]` est forgé à partir du
# slug de l'App.
MEOW_BOT_LOGIN=